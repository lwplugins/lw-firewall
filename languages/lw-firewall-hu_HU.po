#. Plugin Name of the plugin
#: lw-firewall.php
msgid "LW Firewall"
msgstr "LW Firewall"

#. Plugin URI of the plugin
#: lw-firewall.php
msgid "https://github.com/lwplugins/lw-firewall"
msgstr "https://github.com/lwplugins/lw-firewall"

#. Description of the plugin
#: lw-firewall.php
msgid ""
"Lightweight firewall — rate-limits endpoints, blocks bots, bans repeat "
"offenders, and adds security headers."
msgstr ""
"Könnyűsúlyú firewall — rate limitet alkalmaz endpointokra, blokkolja a "
"botokat, kitiltja a visszaesőket, és security headereket ad hozzá."

#. Author of the plugin
#: lw-firewall.php includes/Admin/ParentPage.php:106
#: includes/Admin/ParentPage.php:107 includes/Admin/ParentPage.php:128
msgid "LW Plugins"
msgstr "LW Plugins"

#. Author URI of the plugin
#: lw-firewall.php
msgid "https://lwplugins.com"
msgstr "https://lwplugins.com"

#: includes/Admin/ParentPage.php:129
msgid "Lightweight plugins for WordPress - minimal footprint, maximum impact."
msgstr ""
"Könnyűsúlyú bővítmények WordPresshez – minimális terhelés, maximális hatás."

#: includes/Admin/ParentPage.php:189
msgid "Active"
msgstr "Aktív"

#: includes/Admin/ParentPage.php:197
msgid "Settings"
msgstr "Beállítások"

#: includes/Admin/ParentPage.php:201
msgid "Get Plugin"
msgstr "Bővítmény letöltése"

#: includes/Admin/Settings/ProtectionFields.php:30
msgid "Rate-limit wp-cron.php requests"
msgstr "wp-cron.php kérések rate limitingje"

#: includes/Admin/Settings/ProtectionFields.php:31
msgid "Protects against DDoS attacks targeting wp-cron.php."
msgstr "Véd a wp-cron.php-t célzó DDoS támadások ellen."

#: includes/Admin/Settings/ProtectionFields.php:34
msgid "Rate-limit xmlrpc.php requests"
msgstr "xmlrpc.php kérések rate limitingje"

#: includes/Admin/Settings/ProtectionFields.php:35
msgid "Protects against brute-force and DDoS via xmlrpc.php."
msgstr "Véd a brute-force és DDoS támadások ellen xmlrpc.php-n keresztül."

#: includes/Admin/Settings/ProtectionFields.php:38
msgid "Rate-limit wp-login.php requests"
msgstr "wp-login.php kérések rate limitingje"

#: includes/Admin/Settings/ProtectionFields.php:39
msgid "Rate-limits wp-login.php requests per IP."
msgstr "IP-nként rate limitingeli a wp-login.php kéréseket."

#: includes/Admin/Settings/ProtectionFields.php:42
msgid "Rate-limit REST API requests"
msgstr "REST API kérések rate limitingje"

#: includes/Admin/Settings/ProtectionFields.php:43
msgid "Rate-limits /wp-json/ requests per IP."
msgstr "IP-nként rate limitingeli a /wp-json/ kéréseket."

#: includes/Admin/Settings/ProtectionFields.php:46
msgid "Block 404 flood"
msgstr "404 flood blokkolása"

#: includes/Admin/Settings/ProtectionFields.php:47
msgid "Blocks IPs that generate excessive 404 errors (vulnerability scanning)."
msgstr ""
"Blokkolja azokat az IP-ket, amelyek túl sok 404 hibát generálnak "
"(sebezhetőség-szkennelés)."

#: includes/Admin/Settings/ProtectionFields.php:60
msgid "Enable Login Protection"
msgstr "Bejelentkezés-védelem engedélyezése"

#: includes/Admin/Settings/ProtectionFields.php:61
msgid "Ban IPs after repeated failed logins"
msgstr "IP-k tiltása ismételt sikertelen bejelentkezések után"

#: includes/Admin/Settings/ProtectionFields.php:62
msgid "Counts failed password attempts per IP via wp_login_failed."
msgstr "IP-nként számolja a sikertelen jelszó-próbálkozásokat a wp_login_failed alapján."

#: includes/Admin/Settings/ProtectionFields.php:66
msgid "Failed Attempts"
msgstr "Sikertelen próbálkozások"

#: includes/Admin/Settings/ProtectionFields.php:69
msgid "Number of failed login attempts before the IP is banned."
msgstr "Hány sikertelen bejelentkezés után tiltódik az IP."

#: includes/Admin/Settings/ProtectionFields.php:73
msgid "Detection Window"
msgstr "Észlelési ablak"

#: includes/Admin/Settings/ProtectionFields.php:76
msgid "Seconds within which failed attempts are counted (600 = 10 minutes)."
msgstr "Hány másodpercen belül számítanak a sikertelen próbálkozások (600 = 10 perc)."

#: includes/Admin/Settings/ProtectionFields.php:80
#: includes/Admin/Settings/ProtectionFields.php:109
#: includes/Admin/Settings/SpamFields.php:77
msgid "Ban Duration"
msgstr "Tiltás időtartama"

#: includes/Admin/Settings/ProtectionFields.php:83
#: includes/Admin/Settings/ProtectionFields.php:112
#: includes/Admin/Settings/SpamFields.php:80
msgid "How long the ban lasts in seconds (3600 = 1 hour)."
msgstr "Mennyi ideig tart a tiltás másodpercekben (3600 = 1 óra)."

#: includes/Admin/Settings/ProtectionFields.php:96
msgid "Enable Auto-Ban"
msgstr "Automatikus tiltás engedélyezése"

#: includes/Admin/Settings/ProtectionFields.php:97
msgid "Ban IPs after repeated violations"
msgstr "IP-k tiltása ismételt szabálysértések után"

#: includes/Admin/Settings/ProtectionFields.php:98
msgid ""
"After the threshold is reached, the IP is banned for the configured duration."
msgstr "A küszöb elérése után az IP a beállított időtartamra tiltásra kerül."

#: includes/Admin/Settings/ProtectionFields.php:102
#: includes/Admin/Settings/SpamFields.php:70
msgid "Ban Threshold"
msgstr "Tiltási küszöb"

#: includes/Admin/Settings/ProtectionFields.php:105
msgid "Number of rate-limit violations before an IP is banned."
msgstr "A rate limit megsértéseinek száma, ami után egy IP tiltásra kerül."

#: includes/Admin/Settings/SpamFields.php:30
msgid "Enable Registration Protection"
msgstr "Regisztráció-védelem engedélyezése"

#: includes/Admin/Settings/SpamFields.php:31
msgid "Block bot registrations on wp-login.php?action=register"
msgstr "Bot-regisztrációk blokkolása a wp-login.php?action=register oldalon"

#: includes/Admin/Settings/SpamFields.php:32
msgid ""
"Adds a signed proof-of-render token and honeypot to the registration form. "
"Only active when \"Anyone can register\" is enabled."
msgstr "Aláírt proof-of-render tokent és honeypotot ad a regisztrációs űrlaphoz. Csak akkor aktív, ha az „Anyone can register” engedélyezve van."

#: includes/Admin/Settings/SpamFields.php:35
msgid "Honeypot"
msgstr "Honeypot"

#: includes/Admin/Settings/SpamFields.php:36
msgid "Add a hidden honeypot field"
msgstr "Rejtett honeypot mező hozzáadása"

#: includes/Admin/Settings/SpamFields.php:37
msgid "Catches generic bots that fill every field. Invisible to real users."
msgstr "Elkapja a minden mezőt kitöltő általános botokat. Valódi felhasználók számára láthatatlan."

#: includes/Admin/Settings/SpamFields.php:40
msgid "Single-Use Token"
msgstr "Egyszer használatos token"

#: includes/Admin/Settings/SpamFields.php:41
msgid "Reject reused tokens"
msgstr "Újrahasznált tokenek elutasítása"

#: includes/Admin/Settings/SpamFields.php:42
msgid ""
"Stores used tokens in the firewall storage backend so each rendered form can "
"register only once."
msgstr "A felhasznált tokeneket a tűzfal tárolórétegében tárolja, így minden megjelenített űrlap csak egyszer használható regisztrációra."

#: includes/Admin/Settings/SpamFields.php:46
msgid "Minimum Fill Time"
msgstr "Minimális kitöltési idő"

#: includes/Admin/Settings/SpamFields.php:49
msgid ""
"Reject submissions faster than this many seconds after the form loaded "
"(catches instant bot POSTs)."
msgstr "Elutasítja a beküldéseket, amelyek ennyi másodpercnél gyorsabban érkeznek az űrlap betöltése után (elkapja az azonnali bot-POST-okat)."

#: includes/Admin/Settings/SpamFields.php:53
msgid "Token Lifetime"
msgstr "Token élettartama"

#: includes/Admin/Settings/SpamFields.php:56
msgid "How long a rendered form stays valid, in seconds (3600 = 1 hour)."
msgstr "Meddig érvényes egy megjelenített űrlap, másodpercekben (3600 = 1 óra)."

#: includes/Admin/Settings/SpamFields.php:73
msgid "Number of rejected registrations from one IP before it is banned."
msgstr "Hány elutasított regisztráció után tiltódik egy IP."

#: includes/Admin/Settings/TabBots.php:30
#: includes/Admin/Settings/TabBots.php:45
msgid "Blocked Bots"
msgstr "Blokkolt botok"

#: includes/Admin/Settings/TabBots.php:47
msgid ""
"User-Agent strings to block (one per line, case-insensitive substring match)."
msgstr ""
"Blokkolandó User-Agent stringek (soronként egy, kis- és nagybetűtől "
"független részsztring egyezés)."

#: includes/Admin/Settings/TabBots.php:52
msgid "Blocked User-Agents"
msgstr "Blokkolt User-Agentek"

#: includes/Admin/Settings/TabBots.php:59
msgid ""
"User-Agent substrings (case-insensitive, one per line). Any request whose "
"User-Agent contains one of these is blocked with 403."
msgstr "User-Agent részsztringek (kis-/nagybetű érzéketlen, soronként egy). Minden kérés, amelynek User-Agentje tartalmazza valamelyiket, 403-mal blokkolódik."

#: includes/Admin/Settings/TabGeneral.php:30
msgid "General"
msgstr "Általános"

#: includes/Admin/Settings/TabGeneral.php:45
msgid "General Settings"
msgstr "Általános beállítások"

#: includes/Admin/Settings/TabGeneral.php:47
msgid ""
"Core firewall settings — enable/disable, storage backend, rate limits and "
"filter parameters."
msgstr ""
"Alapvető tűzfalbeállítások — engedélyezés/letiltás, tárolási backend, rate "
"limit-ek és szűrőparaméterek."

#: includes/Admin/Settings/TabGeneral.php:52
msgid "Enable Firewall"
msgstr "Firewall engedélyezése"

#: includes/Admin/Settings/TabGeneral.php:58
msgid "Enable firewall protection"
msgstr "Firewall védelem engedélyezése"

#: includes/Admin/Settings/TabGeneral.php:59
msgid ""
"Master switch — when off, the MU-plugin worker performs no checks (rate-"
"limit, bot blocking, IP/geo blocking, auto-ban all skipped)."
msgstr "Főkapcsoló — kikapcsolva az MU-plugin worker semmilyen ellenőrzést nem végez (rate limiting, bot-blokkolás, IP/geo blokkolás, automatikus tiltás mind kimarad)."

#: includes/Admin/Settings/TabGeneral.php:66
msgid "Storage Backend"
msgstr "Tároló backend"

#: includes/Admin/Settings/TabGeneral.php:73
msgid "Auto-detect"
msgstr "Automatikus felismerés"

#: includes/Admin/Settings/TabGeneral.php:76
msgid "File"
msgstr "Fájl"

#: includes/Admin/Settings/TabGeneral.php:78
msgid ""
"Storage backend for rate-limit counters. Auto-detect tries APCu, then Redis, "
"then file."
msgstr ""
"Tároló backend a rate limit számlálókhoz. Az automatikus felismerés először "
"az APCu-t, majd a Redist, majd a fájlt próbálja."

#: includes/Admin/Settings/TabGeneral.php:85
msgid "Rate Limit"
msgstr "Rate limit"

#: includes/Admin/Settings/TabGeneral.php:93
msgid ""
"Maximum number of rate-limited requests per IP within the time window. "
"Applies to filter parameters, login, REST, XML-RPC and any other protected "
"endpoint."
msgstr "Az IP-nként engedélyezett rate limitelt kérések maximális száma az időablakon belül. Vonatkozik a filter paraméterekre, a bejelentkezésre, a REST-re, az XML-RPC-re és minden más védett végpontra."

#: includes/Admin/Settings/TabGeneral.php:100
msgid "Time Window"
msgstr "Időablak"

#: includes/Admin/Settings/TabGeneral.php:108
msgid "Time window in seconds for rate limiting."
msgstr "Időablak másodpercben a rate limitinghez."

#: includes/Admin/Settings/TabGeneral.php:115
msgid "Rate Limit Action"
msgstr "Rate limit művelet"

#: includes/Admin/Settings/TabGeneral.php:122
msgid "302 Redirect (strip filters)"
msgstr "302 átirányítás (filterek eltávolítása)"

#: includes/Admin/Settings/TabGeneral.php:123
msgid "429 Too Many Requests"
msgstr "429 Túl sok kérés"

#: includes/Admin/Settings/TabGeneral.php:125
msgid ""
"Response when the rate limit is exceeded. 302 strips query parameters and "
"redirects to the same path; 429 returns a Retry-After header."
msgstr "Válasz a rate limit túllépésekor. A 302 eltávolítja a query paramétereket és ugyanarra az útvonalra irányít át; a 429 Retry-After fejlécet ad vissza."

#: includes/Admin/Settings/TabGeneral.php:132
msgid "Filter Parameters"
msgstr "Filter paraméterek"

#: includes/Admin/Settings/TabGeneral.php:139
msgid ""
"URL parameter substrings to rate-limit, one per line. Append |N for a "
"stricter per-prefix limit (e.g. add-to-cart|10). Defaults: filter_|30, "
"query_type_|30."
msgstr "Rate limitelendő URL-paraméter részsztringek, soronként egy. Fűzz hozzá |N-t szigorúbb, prefixenkénti limithez (pl. add-to-cart|10). Alapértelmezések: filter_|30, query_type_|30."

#: includes/Admin/Settings/TabGeo.php:32 includes/Admin/Settings/TabGeo.php:47
msgid "Geo Blocking"
msgstr "Geo blokkolás"

#: includes/Admin/Settings/TabGeo.php:49
msgid ""
"Block visitors from specific countries. Behind Cloudflare, the CF-IPCountry "
"header is used (instant). Without Cloudflare, CIDR-based lookup is used "
"(updated weekly)."
msgstr "Bizonyos országokból érkező látogatók blokkolása. Cloudflare mögött a CF-IPCountry fejléc használatos (azonnali). Cloudflare nélkül CIDR-alapú keresés (hetente frissül)."

#: includes/Admin/Settings/TabGeo.php:68
msgid "Enable"
msgstr "Engedélyezés"

#: includes/Admin/Settings/TabGeo.php:74
msgid "Enable Geo Blocking"
msgstr "Geo blokkolás engedélyezése"

#: includes/Admin/Settings/TabGeo.php:89
msgid "Block Action"
msgstr "Blokkolási művelet"

#: includes/Admin/Settings/TabGeo.php:97
msgid "403 Forbidden"
msgstr "403 Forbidden"

#: includes/Admin/Settings/TabGeo.php:98
msgid "Redirect to homepage"
msgstr "Átirányítás a főoldalra"

#: includes/Admin/Settings/TabGeo.php:114
msgid "Blocked Countries"
msgstr "Tiltott országok"

#: includes/Admin/Settings/TabGeo.php:121
msgid "ISO 3166-1 alpha-2 country codes, one per line (e.g. IN, CN, RU)."
msgstr "ISO 3166-1 alpha-2 országkódok, soronként egy (pl. IN, CN, RU)."

#: includes/Admin/Settings/TabGeo.php:138
msgid "Update CIDR Lists Now"
msgstr "CIDR listák frissítése most"

#. translators: %s: human-readable time difference
#: includes/Admin/Settings/TabGeo.php:144
#, php-format
msgid "Next automatic update: %s"
msgstr "Következő automatikus frissítés: %s"

#: includes/Admin/Settings/TabImportExport.php:28
msgid "Import / Export"
msgstr "Importálás / Exportálás"

#: includes/Admin/Settings/TabImportExport.php:53
#: includes/Admin/Settings/TabImportExport.php:59
msgid "Export Settings"
msgstr "Beállítások exportálása"

#: includes/Admin/Settings/TabImportExport.php:55
msgid ""
"Download your current firewall settings as a JSON file. You can use this "
"file to import settings on another site."
msgstr "Töltsd le a jelenlegi tűzfal beállításaidat JSON-fájlként. Ezzel a fájllal egy másik oldalon importálhatod a beállításokat."

#: includes/Admin/Settings/TabImportExport.php:73
#: includes/Admin/Settings/TabImportExport.php:92
msgid "Import Settings"
msgstr "Beállítások importálása"

#: includes/Admin/Settings/TabImportExport.php:75
msgid ""
"Upload a previously exported JSON file to restore firewall settings. This "
"will overwrite all current settings."
msgstr "Tölts fel egy korábban exportált JSON-fájlt a tűzfal beállítások visszaállításához. Ez felülír minden jelenlegi beállítást."

#: includes/Admin/Settings/TabImportExport.php:83
msgid "Settings File"
msgstr "Beállításfájl"

#: includes/Admin/Settings/TabImportExport.php:107
msgid "Settings imported successfully."
msgstr "A beállítások sikeresen importálva."

#: includes/Admin/Settings/TabImportExport.php:116
msgid "No file was uploaded."
msgstr "Nem lett fájl feltöltve."

#: includes/Admin/Settings/TabImportExport.php:117
msgid "Could not read the uploaded file."
msgstr "A feltöltött fájl nem olvasható."

#: includes/Admin/Settings/TabImportExport.php:118
msgid "The file does not contain valid JSON."
msgstr "A fájl nem tartalmaz érvényes JSON-t."

#: includes/Admin/Settings/TabImportExport.php:121
msgid "Import failed."
msgstr "Az importálás sikertelen."

#: includes/Admin/Settings/TabIpRules.php:30
#: includes/Admin/Settings/TabIpRules.php:45
msgid "IP Rules"
msgstr "IP szabályok"

#: includes/Admin/Settings/TabIpRules.php:47
msgid ""
"Manually allow or block IP addresses. Supports individual IPs and CIDR "
"ranges (e.g. 192.168.1.0/24)."
msgstr ""
"IP-címek kézi engedélyezése vagy blokkolása. Támogatja az egyedi IP-ket és a "
"CIDR tartományokat (pl. 192.168.1.0/24)."

#: includes/Admin/Settings/TabIpRules.php:52
msgid "IP Whitelist"
msgstr "IP whitelist"

#: includes/Admin/Settings/TabIpRules.php:59
msgid ""
"IPs or CIDR ranges that bypass all firewall checks (one per line). Supports "
"IPv4, IPv6, and CIDR notation (e.g. 10.0.0.0/8, 2001:db8::/32)."
msgstr "IP-k vagy CIDR tartományok, amelyek minden tűzfal-ellenőrzést kihagynak (soronként egy). Támogatja az IPv4, IPv6 és CIDR jelölést (pl. 10.0.0.0/8, 2001:db8::/32)."

#: includes/Admin/Settings/TabIpRules.php:66
msgid "IP Blacklist"
msgstr "IP blacklist"

#: includes/Admin/Settings/TabIpRules.php:73
msgid ""
"IPs or CIDR ranges blocked with 403 Forbidden before any other check (one "
"per line). Supports IPv4, IPv6, and CIDR notation."
msgstr "IP-k vagy CIDR tartományok, amelyek minden más ellenőrzés előtt 403 Forbidden-nel blokkolódnak (soronként egy). Támogatja az IPv4, IPv6 és CIDR jelölést."

#: includes/Admin/Settings/TabLogs.php:32
msgid "Logs"
msgstr "Naplók"

#: includes/Admin/Settings/TabLogs.php:47
msgid "Request Logging"
msgstr "Kérések naplózása"

#: includes/Admin/Settings/TabLogs.php:51
msgid "Enable Logging"
msgstr "Naplózás engedélyezése"

#: includes/Admin/Settings/TabLogs.php:57
msgid "Log blocked requests"
msgstr "Blokkolt kérések naplózása"

#: includes/Admin/Settings/TabLogs.php:58
msgid "Stores the last 100 blocked requests in the database."
msgstr "Az utolsó 100 blokkolt kérést eltárolja az adatbázisban."

#: includes/Admin/Settings/TabLogs.php:71
msgid "Clear all log entries on save"
msgstr "Mentéskor az összes naplóbejegyzés törlése"

#: includes/Admin/Settings/TabLogs.php:86
msgid "No log entries yet."
msgstr "Még nincsenek naplóbejegyzések."

#: includes/Admin/Settings/TabLogs.php:94
msgid "Time"
msgstr "Idő"

#: includes/Admin/Settings/TabLogs.php:95
msgid "IP"
msgstr "IP"

#: includes/Admin/Settings/TabLogs.php:96
msgid "Reason"
msgstr "Ok"

#: includes/Admin/Settings/TabLogs.php:97
msgid "User-Agent"
msgstr "User-Agent"

#: includes/Admin/Settings/TabLogs.php:98
msgid "URL"
msgstr "URL"

#: includes/Admin/Settings/TabProtection.php:30
msgid "Protection"
msgstr "Védelem"

#: includes/Admin/Settings/TabProtection.php:45
msgid "Endpoint Protection"
msgstr "Endpoint-védelem"

#: includes/Admin/Settings/TabProtection.php:46
msgid "Enable rate limiting on specific WordPress endpoints."
msgstr "Engedélyezd a rate limitinget bizonyos WordPress endpointokon."

#: includes/Admin/Settings/TabProtection.php:51
msgid "Brute-Force Login Protection"
msgstr "Brute-force bejelentkezés-védelem"

#: includes/Admin/Settings/TabProtection.php:52
msgid ""
"Ban IPs that submit too many failed login attempts (fail2ban style). A "
"banned IP is blocked from the whole site, not just wp-login.php."
msgstr "Tiltsa azokat az IP-ket, amelyek túl sok sikertelen bejelentkezést küldenek (fail2ban-stílus). A tiltott IP az egész oldalról ki van zárva, nem csak a wp-login.php-ról."

#: includes/Admin/Settings/TabProtection.php:57
msgid "Auto-Ban"
msgstr "Automatikus tiltás"

#: includes/Admin/Settings/TabProtection.php:58
msgid "Automatically ban IPs that repeatedly exceed rate limits."
msgstr ""
"Automatikusan kitiltja azokat az IP-ket, amelyek ismételten túllépik a rate "
"limitet."

#: includes/Admin/Settings/TabSecurity.php:30
msgid "Security"
msgstr "Biztonság"

#: includes/Admin/Settings/TabSecurity.php:45
msgid "Security Headers"
msgstr "Biztonsági headerek"

#: includes/Admin/Settings/TabSecurity.php:47
msgid "Add security-related HTTP response headers to every page."
msgstr ""
"Biztonsággal kapcsolatos HTTP válaszheaderek hozzáadása minden oldalhoz."

#: includes/Admin/Settings/TabSecurity.php:52
msgid "Enable Security Headers"
msgstr "Biztonsági headerek engedélyezése"

#: includes/Admin/Settings/TabSecurity.php:58
msgid "Add security headers to all responses"
msgstr "Biztonsági headerek hozzáadása minden válaszhoz"

#: includes/Admin/Settings/TabSecurity.php:65
msgid "Headers added:"
msgstr "Hozzáadott headerek:"

#: includes/Admin/Settings/TabSecurity.php:78
msgid "What do these headers do?"
msgstr "Mire valók ezek a headerek?"

#: includes/Admin/Settings/TabSecurity.php:84
msgid ""
"Prevents browsers from MIME-sniffing the content type. Without this, a "
"browser might interpret a file differently than intended — for example, "
"treating a text file as JavaScript — which can lead to XSS attacks."
msgstr ""
"Megakadályozza, hogy a böngészők MIME-sniffinggel kitalálják a content type-"
"ot. Enélkül a böngésző a fájlt a szándéktól eltérően értelmezheti — például "
"egy szövegfájlt JavaScriptként — ami XSS támadásokhoz vezethet."

#: includes/Admin/Settings/TabSecurity.php:90
msgid ""
"Prevents your site from being embedded in an iframe on another domain. This "
"protects against clickjacking attacks, where a malicious site overlays your "
"page with invisible elements to trick users into clicking."
msgstr ""
"Megakadályozza, hogy a webhelyedet egy másik domainen iframe-be ágyazzák. Ez "
"véd a clickjacking támadások ellen, amikor egy rosszindulatú oldal "
"láthatatlan elemekkel takarja le az oldaladat, hogy rávegye a felhasználókat "
"a kattintásra."

#: includes/Admin/Settings/TabSecurity.php:96
msgid ""
"Controls how much referrer information is sent when navigating away from "
"your site. The \"strict-origin-when-cross-origin\" value sends the full URL "
"for same-origin requests but only the origin (domain) for cross-origin "
"requests, preventing sensitive URL paths from leaking to third parties."
msgstr ""
"Szabályozza, mennyi referrer információ kerül elküldésre, amikor elnavigálsz "
"a webhelyedről. A \"strict-origin-when-cross-origin\" érték same-origin "
"kéréseknél a teljes URL-t küldi, cross-origin kéréseknél viszont csak az "
"origint (domaint), megakadályozva, hogy érzékeny URL útvonalak harmadik "
"felekhez kerüljenek."

#: includes/Admin/Settings/TabSecurity.php:102
msgid ""
"Disables browser features that your site does not use — camera, microphone, "
"and geolocation. This prevents malicious scripts (e.g. from compromised "
"third-party libraries) from silently accessing these sensitive APIs."
msgstr ""
"Kikapcsolja azokat a böngészőfunkciókat, amiket a webhelyed nem használ — "
"kamera, mikrofon és geolokáció. Ez megakadályozza, hogy rosszindulatú "
"scriptek (pl. kompromittált third-party library-kből) észrevétlenül "
"hozzáférjenek ezekhez az érzékeny API-khoz."

#: includes/Admin/Settings/TabSecurity.php:108
msgid ""
"Enables the built-in XSS filter in older browsers (IE, older Chrome). When a "
"reflected XSS attack is detected, the browser blocks the page instead of "
"rendering it. Modern browsers use Content-Security-Policy instead, but this "
"header provides a safety net for legacy browsers."
msgstr ""
"Bekapcsolja a beépített XSS szűrőt a régebbi böngészőkben (IE, régebbi "
"Chrome). Ha reflected XSS támadást észlel, a böngésző az oldal renderelése "
"helyett blokkolja azt. A modern böngészők inkább a Content-Security-Policy-t "
"használják, de ez a header egy plusz védőhálót ad a legacy böngészőknek."

